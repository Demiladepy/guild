# testnet = Base Sepolia (dev flow) | mainnet = Base (1Shot prize qualification)
CHAIN_MODE=testnet
NEXT_PUBLIC_CHAIN_MODE=testnet

# Base Sepolia execution RPC (testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Base mainnet RPC (when CHAIN_MODE=mainnet)
BASE_RPC_URL=https://mainnet.base.org

# ERC-4337 v0.7 bundler endpoint for Base Sepolia
BUNDLER_RPC_URL=

# Venice AI inference
VENICE_API_KEY=
VENICE_MODEL=

# Wallet that receives inference USDC payment (server + client)
X402_PAYTO_ADDRESS=
NEXT_PUBLIC_X402_PAYTO_ADDRESS=

# Public app URL for 1Shot webhook push (use ngrok/tunnel for local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Settlement: x402 (default) | relayer (1Shot mainnet prize path)
RELAYER_MODE=x402
NEXT_PUBLIC_RELAYER_MODE=x402

# When RELAYER_MODE=relayer also set:
# CHAIN_MODE=mainnet
# NEXT_PUBLIC_CHAIN_MODE=mainnet
# NEXT_PUBLIC_APP_URL=https://your-tunnel.ngrok.app
# NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
