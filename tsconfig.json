{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@guild/core": ["./packages/core/src/index.ts"],
      "@guild/core/*": ["./packages/core/src/*"]
    }
  },
  "exclude": ["node_modules", "apps/web/.next"]
}
